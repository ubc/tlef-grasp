# Framework behavior / cookie security only (production | development).
NODE_ENV=development
TLEF_GRASP_PORT=8070

# The purpose of this constant is to grant users who are not faculty members with faculty role. The list includes user PUIDs separated by comma.
APP_ADMINISTRATOR=11223344,11223345

# --- Session Management ---
# A long, random string used to sign the session ID cookie.
SESSION_SECRET=your_session_secret_here
# Session timeout in milliseconds (Default: 7200000 = 2 hours)
SESSION_TIMEOUT_MS=7200000

# --- SAML (Single Sign-On / Single Log-Out) Configuration ---
# These values MUST correspond to the configuration of your SAML Identity Provider (IdP).
# For local development, this is likely the `docker-simple-saml` project.
SAML_ENVIRONMENT=LOCAL
SAML_ISSUER=http://localhost:8070
# Route defined under routes/auth.js
SAML_CALLBACK_URL=http://localhost:8070/auth/saml/callback
# absolute path to the file docker-simple-saml/cert/server.pem
SAML_PRIVATE_KEY_PATH=/path/to/server.pem
# absolute path to the file docker-simple-saml/cert/server.crt
SAML_CERT_PATH=/path/to/server.crt

# MONGO_DB Configs
MONGODB_URI=mongodb://username:password@localhost:27017
MONGODB_DB_NAME=tlef_grasp
 
# LLM Configs
# LLM_PROVIDER selects the provider + models, independent of NODE_ENV:
#   ollama -> local Ollama (OLLAMA_* models), openai -> OpenAI (OPENAI_* models). Defaults to openai when unset.
LLM_PROVIDER=ollama
# Models are picked per provider: OLLAMA_* used when LLM_PROVIDER=ollama, OPENAI_* when openai.

# --- Provider connection details ---
OPENAI_API_KEY=your_openai_api_key_here
OLLAMA_ENDPOINT=http://localhost:11434

# --- Production models (OpenAI) ---
OPENAI_LLM_MODEL=gpt-5.4-mini
OPENAI_REVIEW_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Vision model for transcribing images in PDFs. Optional — defaults to OPENAI_LLM_MODEL if unset.
OPENAI_VISION_MODEL=gpt-5.4-mini

# --- Development models (Ollama) ---
# Use models you have pulled locally. The embedding model must match
# QDRANT_VECTOR_SIZE below (e.g. nomic-embed-text -> 768).
OLLAMA_LLM_MODEL=Qwen3:0.6B
OLLAMA_REVIEW_MODEL=Qwen3:0.6B
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Vision model for transcribing images in PDFs. Optional — defaults to OLLAMA_LLM_MODEL if unset.
# Must be a multimodal model (e.g. qwen2.5vl, llava, gemma3:4b); pull it first.
OLLAMA_VISION_MODEL=qwen2.5vl:7b

EMBEDDING_PROVIDER=ubc-genai-toolkit-llm

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=question-generation-collection
QDRANT_API_KEY=your_qdrant_api_key_here
# Vector size per stage — must match the embedding model's output dimension.
OPENAI_QDRANT_VECTOR_SIZE=1536
OLLAMA_QDRANT_VECTOR_SIZE=768

# Course Lookup
UBC_API_ENV=prod
UBC_API_CLIENT_ID=your_ubc_api_client_id_here
UBC_API_CLIENT_SECRET=your_ubc_api_client_secret_here
