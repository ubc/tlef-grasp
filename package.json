{
  "name": "tlef-grasp",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.js",
  "scripts": {
    "start": "cross-env NODE_ENV=production node src/server.js",
    "start:test": "cross-env NODE_ENV=test node src/server.js",
    "dev": "npm-run-all --parallel dev:*",
    "dev:server": "nodemon --watch src src/server.js",
    "dev:client": "npm --prefix client run watch",
    "build": "npm --prefix client run build",
    "test": "jest",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:unit:coverage": "jest --coverage",
    "test:unit:monocart": "jest -c jest.monocart.config.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:a11y": "playwright test --config=playwright.a11y.config.js",
    "test:a11y:headed": "playwright test --config=playwright.a11y.config.js --headed",
    "test:a11y:debug": "playwright test --config=playwright.a11y.config.js --debug",
    "test:a11y:report": "playwright show-report playwright-report-a11y",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@llamaindex/liteparse": "^1.5.3",
    "@ubc/ubc-genai-toolkit-course-list-sync": "^0.1.3",
    "archiver": "^7.0.1",
    "cheerio": "^1.1.2",
    "connect-mongo": "^6.0.0",
    "dotenv": "^17.0.1",
    "expr-eval": "^2.0.2",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "fastembed": "^2.0.0",
    "helmet": "^8.1.0",
    "jsdom": "^27.0.1",
    "mammoth": "^1.12.0",
    "mongodb": "^6.18.0",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-saml": "^3.2.4",
    "passport-ubcshib": "^0.1.6",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.34.5",
    "ubc-genai-toolkit-chunking": "^0.1.0",
    "ubc-genai-toolkit-core": "^0.1.0",
    "ubc-genai-toolkit-document-parsing": "^0.2.0",
    "ubc-genai-toolkit-embeddings": "^0.1.1",
    "ubc-genai-toolkit-llm": "^0.3.0",
    "ubc-genai-toolkit-rag": "^0.1.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "browser-sync": "^3.0.4",
    "cross-env": "^7.0.3",
    "jest": "^30.2.0",
    "jest-monocart-coverage": "^1.1.1",
    "monocart-reporter": "^2.12.2",
    "nodemon": "^3.1.10",
    "npm-run-all": "^4.1.5",
    "supertest": "^7.1.4"
  }
}
